# ==========================================================================

# Anomaly Detection in ECG Signals of Heart Disease Prediction using Deep Learning Techniques

# Environment Variables

#

# Project Lead: Ashfakur Rahman

# Repository: https://github.com/ashfak-g/ECG-Anomaly-Detection-Heart-Disease-Prediction

#

# Copy this file to .env and fill in real values.

# ==========================================================================

# ---------- Core ----------

SECRET_KEY=your-secret-key-here-change-me
FLASK_ENV=production

# ---------- PostgreSQL ----------

DATABASE_URL=postgresql://heart_user:your_password@localhost:5432/heart_anomalies
POSTGRES_USER=heart_user
POSTGRES_PASSWORD=your_password
POSTGRES_DB=heart_anomalies

# ---------- Gemini AI ----------

GEMINI_API_KEY=your-gemini-api-key

# ---------- Rate Limiting (Redis) ----------

# Use redis://localhost:6379/0 on your machine

RATELIMIT_STORAGE_URI=redis://localhost:6379/0

# ---------- JWT API Layer ----------

JWT_SECRET_KEY=your-jwt-secret-key-here

# ---------- Email Configuration (Gmail SMTP) ----------

# Required for appointment status notifications and password reset OTP

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=[your-email@gmail.com](mailto:your-email@gmail.com)
MAIL_PASSWORD=your-gmail-app-password
MAIL_DEFAULT_SENDER=[your-email@gmail.com](mailto:your-email@gmail.com)
MAIL_SENDER_NAME="Anomaly Detection in ECG Signals Team"

# ---------- Password Reset OTP ----------

OTP_LENGTH=6
OTP_EXPIRY_SECONDS=600
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ---------- Gunicorn ----------

GUNICORN_BIND=0.0.0.0:5000
GUNICORN_WORKERS=4
GUNICORN_LOG_LEVEL=info
